{
	"schemaVersion": 1,
	"id": "tabrenamer",
	"version": "${version}",
	"name": "TabRenamer",
	"description": "A simple mod that allows server admins to visually replace player names in the client-side Tab list.",
	"authors": [
		"Moralts"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/tabrenamer",
		"sources": "https://github.com/Moralts/TabRenamer-Mod"
	},
	"license": "Apache License-2.0",
	"icon": "assets/tabrenamer/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "com.tabrenamer.moralts.TabRenamer",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "com.tabrenamer.moralts.client.TabRenamerClient",
				"adapter": "kotlin"
			}
		],
		"modmenu": [
			"com.tabrenamer.moralts.client.ModMenuIntegration"
		]
	},
	"mixins": [
		"tabrenamer.mixins.json",
		{
			"config": "tabrenamer.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.9",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*",
		"fabric-language-kotlin": "*",
		"cloth-config": ">=11.0.0"
	},
	"suggests": {
		"modmenu": ">=7.0.0"
	}
}